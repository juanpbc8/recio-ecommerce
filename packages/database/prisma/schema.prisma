generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)
  slug String @unique @db.VarChar(150)

  // Relación recursiva (Auto-referencia) para subcategorías:
  // Es opcional (Int?) porque una categoría raíz no tiene padre.
  parentId Int? @map("parent_id")

  // Campo de Relación (Objeto): Para acceder al padre (como @ManyToOne en JPA).
  // Se requiere un nombre "CategoryToCategory" porque Prisma necesita saber qué campo conecta con cuál en la misma tabla.
  parent Category? @relation("CategoryToCategory", fields: [parentId], references: [id])

  // Campo de Relación (Lista): Para acceder a las subcategorías (como @OneToMany con mappedBy en JPA).
  subCategories Category[] @relation("CategoryToCategory")

  // --- RELACIÓN CON PRODUCTOS ---
  // Lado "Uno" de la relación One-to-Many con Product. No lleva @relation porque el FK está en la tabla Product.
  products Product[]

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  description String        @db.Text
  slug        String        @unique @db.VarChar(255)
  status      ProductStatus @default(ACTIVE)
  isNew       Boolean       @default(false) @map("is_new")
  isOnSale    Boolean       @default(false) @map("is_on_sale")

  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)

  // FK y Relación
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  // --- RELACIÓN CON VARIANTES E IMÁGENES ---
  // Lado "Uno": Un producto tiene una lista de variantes e imágenes. 
  variants ProductVariant[]
  images   ProductImage[]

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isNew])
  @@index([isOnSale])
  @@map("products")
}

model ProductVariant {
  id    Int    @id @default(autoincrement())
  sku   String @unique @db.VarChar(100)
  stock Int    @default(0)
  color String @db.VarChar(50)
  size  String @db.VarChar(20)

  // FK y Relación
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  // Auditoría
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([color])
  @@map("product_variants")
}

model ProductImage {
  id           Int     @id @default(autoincrement())
  url          String  @db.Text
  altText      String? @map("alt_text") @db.VarChar(255)
  variantColor String? @map("variant_color") @db.VarChar(50)
  isMain       Boolean @default(false) @map("is_main")

  // FK y Relación
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([variantColor])
  @@map("product_images")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum DocumentType {
  DNI
  RUC
  CE
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AddressType {
  RESIDENTIAL
  WORK
}

enum InvoiceStatus {
  PENDING
  ISSUED
  CANCELLED
  ERROR
}

enum InvoiceType {
  BOLETA
  FACTURA
}

model User {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  passwordHash   String        @map("password_hash")
  firstName      String?       @map("first_name") @db.VarChar(100)
  lastName       String?       @map("last_name") @db.VarChar(100)
  phone          String?       @db.VarChar(20)
  documentType   DocumentType? @default(DNI) @map("document_type")
  documentNumber String?       @map("document_number") @db.VarChar(20)
  role           Role          @default(CUSTOMER)

  addresses UserAddress[]
  orders    Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([documentNumber])
  @@map("users")
}

model UserAddress {
  id               Int         @id @default(autoincrement())
  addressLine      String      @map("address_line")
  department       String      @db.VarChar(60)
  province         String      @db.VarChar(60)
  district         String      @db.VarChar(60)
  reference        String?     @db.VarChar(150)
  isDefault        Boolean     @default(false) @map("is_default")
  type             AddressType
  // Contacto específico para esta dirección
  contactFirstName String?     @map("contact_first_name") @db.VarChar(100)
  contactLastName  String?     @map("contact_last_name") @db.VarChar(100)
  contactPhone     String?     @map("contact_phone") @db.VarChar(20)

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id])

  @@map("user_addresses")
}

model Order {
  id         Int         @id @default(autoincrement())
  totalPrice Decimal     @map("total_price") @db.Decimal(10, 2)
  status     OrderStatus @default(PENDING)
  notes      String?     @db.Text

  // Snapshot de Identidad (Para Boleta/Factura quién compra)
  customerEmail     String       @map("customer_email")
  customerFirstName String       @map("customer_first_name")
  customerLastName  String       @map("customer_last_name")
  customerDocType   DocumentType @map("customer_doc_type")
  customerDocNum    String       @map("customer_doc_num")
  customerPhone     String       @map("customer_phone") @db.VarChar(20)

  // Relaciones
  shippingAddress OrderAddress? // Snapshot de Envío (Donde llega el paquete)
  userId          Int?          @map("user_id") // Opcional para permitir Invitados
  user            User?         @relation(fields: [userId], references: [id])

  items   OrderItem[]
  invoice Invoice?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerDocNum])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderAddress {
  id               Int     @id @default(autoincrement())
  addressLine      String  @map("address_line")
  department       String  @db.VarChar(60)
  province         String  @db.VarChar(60)
  district         String  @db.VarChar(60)
  reference        String? @db.VarChar(150)
  // Contacto de Entrega - Importante para el courier/tercero de logística
  contactFirstName String  @map("contact_first_name") @db.VarChar(100)
  contactLastName  String  @map("contact_last_name") @db.VarChar(100)
  contactPhone     String  @map("contact_phone") @db.VarChar(20)

  orderId Int   @unique @map("order_id")
  order   Order @relation(fields: [orderId], references: [id])

  @@map("order_addresses")
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  priceAtPurchase Decimal @map("price_at_purchase") @db.Decimal(10, 2)
  quantity        Int

  orderId   Int            @map("order_id")
  order     Order          @relation(fields: [orderId], references: [id])
  variantId Int            @map("variant_id")
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Invoice {
  id          Int           @id @default(autoincrement())
  totalAmount Decimal       @map("total_amount") @db.Decimal(10, 2)
  serie       String        @db.VarChar(4) // Ej: "F001" o "B001"
  number      String        @db.VarChar(8) // Ej: "000054"
  type        InvoiceType   @default(BOLETA)
  status      InvoiceStatus @default(PENDING)
  pdfUrl      String?       @map("pdf_url")
  hashCode    String?       @map("hash_code") @db.VarChar(255)

  orderId Int   @unique @map("order_id")
  order   Order @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  // Para que no existan dos facturas con la misma serie y número
  @@unique([serie, number])
  @@map("invoices")
}
