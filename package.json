{
  "name": "recio-ecommerce",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo para un E-commerce",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:gen": "turbo run db:gen --filter=@repo/database",
    "db:migrate": "turbo run db:migrate --filter=@repo/database",
    "db:push": "turbo run db:push --filter=@repo/database",
    "db:studio": "turbo run db:studio --filter=@repo/database"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
